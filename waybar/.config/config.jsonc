{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 0,
    "margin-top": 8,
    "margin-left": 16,
    "margin-right": 16,
    "margin-bottom": 0,

    "modules-left": ["hyprland/workspaces", "separator", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["group/stats", "separator", "pulseaudio", "separator", "network", "separator", "battery", "tray"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 50,
        "separate-outputs": true,
        "rewrite": {
            "(.*) - Mozilla Firefox": "َ°ˆ¹ $1",
            "(.*)Neovim(.*)": "َ°ٹ„ $1",
            "(.*)foot(.*)": " $1",
            "(.*)btop(.*)": "َ°¨‡ btop"
        }
    },

    "separator": {
        "format": "|",
        "interval": "once",
        "tooltip": false
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %B %d %Y â€” %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    },

    "group/stats": {
        "orientation": "horizontal",
        "modules": ["custom/temp", "cpu", "memory", "custom/disk"]
    },

    "custom/temp": {
        "exec": "waybar-temp",
        "return-type": "json",
        "interval": 3,
        "tooltip": false
    },

    "cpu": {
        "format": "َ°»  {usage}%",
        "interval": 3,
        "on-click": "foot -e btop",
        "tooltip": false
    },

    "memory": {
        "format": "َ°چ› {percentage}%",
        "interval": 3,
        "on-click": "foot -e btop",
        "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
    },

    "custom/disk": {
        "exec": "waybar-disk",
        "return-type": "json",
        "interval": 60,
        "tooltip": true
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-full": "َ°پ¹ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "tooltip-format": "{timeTo}"
    },

    "network": {
        "format-wifi": "َ°¤¨ {signalStrength}%",
        "format-ethernet": "َ°ˆ€ eth",
        "format-disconnected": "َ°¤­",
        "tooltip-format-wifi": "{essid}\n{ipAddr}\n{signalStrength}%",
        "interval": 30
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°–پ",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 5,
        "tooltip": false
    },

    "tray": {
        "spacing": 8,
        "icon-size": 14
    }
}
