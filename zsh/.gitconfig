[user]
    name = BuggingHere
    email = 77539480+BuggingHere@users.noreply.github.com

[core]
    editor = nvim
    pager = delta
    autocrlf = input

[init]
    defaultBranch = main

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = base16

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[fetch]
    prune = true

[rerere]
    enabled = true

[color]
    ui = auto

[alias]
    s = status -sb
    a = add
    aa = add --all
    c = commit
    cm = commit -m
    p = push
    pl = pull
    l = log --oneline --graph --decorate
    ll = log --oneline --graph --decorate --all
    d = diff
    ds = diff --staged
    co = checkout
    cb = checkout -b
    b = branch
    ba = branch -a
    st = stash
    stp = stash pop
    undo = reset --soft HEAD~1
    unstage = restore --staged
    aliases = config --get-regexp alias
