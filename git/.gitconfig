[user]
	email = 77539480+BuggingHere@users.noreply.github.com
	name = BuggingHere

[core]
    editor      = nvim
    autocrlf    = input                     ; safer on Linux/macOS
    quotepath   = false                     ; show unicode filenames properly
    excludesfile = ~/.gitignore_global      ; global ignore file (see below)
    pager       = less -FRX                 ; better pager defaults

[init]
    defaultBranch = main                    ; most people prefer main now

[alias]
    # Very commonly used shortcuts
    co      = checkout
    ci      = commit
    st      = status -sb
    br      = branch
    lg      = log --graph --oneline --decorate --all
    ll      = log --pretty=format:"%C(yellow)%h %Cblue%>(12)%ad %Cgreen%<(7)%aN%Cred%d %Creset%s" --date=short --abbrev-commit
    amend   = commit --amend --no-edit
    unstage = reset HEAD --
    undo    = reset --soft HEAD~1
    last    = log -1 --stat
    who     = shortlog -sne --since="1 month ago"
    cleanup = !git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d

    # Interactive rebase shortcuts
    ri      = rebase --interactive
    ria     = rebase --autosquash --interactive

    # Nice visual diffs
    df      = diff --color-words
    ds      = diff --staged --color-words

[commit]
    # Very useful: shows what has changed when writing commit message
    verbose = true
    # template = ~/.gitmessage               ; optional (see below)

[push]
    default = current                       ; push current branch only
    autoSetupRemote = true                  ; git push -u origin main → automatically sets upstream

[pull]
    rebase  = true                          ; pull --rebase by default (cleaner history)
    ff      = only                          ; refuse to merge if not fast-forward

[rebase]
    autosquash = true                       ; automatically squash fixup! commits
    autostash  = true                       ; stash before rebase, apply after

[merge]
    conflictStyle = zdiff3                  ; better conflict markers (three-dot style)
    tool          = nvimdiff

[diff]
    tool    = nvimdiff
    colorMoved = zebra                      ; highlights moved lines nicely

[fetch]
    prune = true                            ; automatically remove remote branches that are gone

[filter "lfs"]
    required = true                         ; if you use Git LFS

[color]
    ui = auto                               ; colors almost everywhere

# Optional: nicer pager colors (works well in dark themes)
[color "diff"]
    meta       = cyan bold
    frag       = magenta bold
    func       = blue
    commit     = green bold
    old        = red bold
    new        = green bold
    whitespace = red reverse

[color "branch"]
    current = yellow reverse
    local   = yellow
    remote  = cyan

[color "status"]
    added     = green
    changed   = yellow
    untracked = red
